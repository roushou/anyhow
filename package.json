{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "bun run lint && bun run format:check && bun run typecheck",
    "release": "bun run --filter '*' release"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "typescript": "^6"
  }
}
